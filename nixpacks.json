{
  "providers": ["node"],
  "phases": {
    "setup": {
      "nixPkgs": ["nodejs_22", "npm-9_x", "openssl"]
    },
    "install": {
      "cmds": ["npm ci"]
    },
    "build": {
      "cmds": ["npx prisma generate", "npm run build"]
    }
  },
  "start": {
    "cmd": "npx prisma db push && node .next/standalone/server.js"
  }
}