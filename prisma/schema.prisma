// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  image         String?
  role          String    @default("USER") // USER, CREATOR, ADMIN
  resetToken    String?
  resetTokenExpiry DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  favorites     Product[] @relation("UserFavorites")
  purchases     Order[]
  createdProducts Product[] @relation("UserProducts")
}

model Product {
  id          String   @id @default(uuid())
  slug        String   @unique @default(cuid()) // Default to cuid to handle existing records
  title       String
  description String
  price       Float
  previewUrl  String   // Path to the model3.json file relative to public folder or S3 URL
  fileUrl     String   // Path to the downloadable zip file (secure location)
  iconUrl     String?  // Path to the icon image
  isSold      Boolean  @default(false)
  sex         String?  // Male, Female, Other
  eyeColor    String?
  hairColor   String?
  bodyType    String?
  theme       String?
  tags        String[] // General tags
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Order       Order[]
  favoritedBy User[]   @relation("UserFavorites")
  creatorId   String?
  creator     User?    @relation("UserProducts", fields: [creatorId], references: [id])
}

model Order {
  id            String   @id @default(uuid())
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  buyerEmail    String
  status        String   // PENDING, COMPLETED
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
}
