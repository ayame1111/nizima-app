// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  slug          String?   @unique // Custom username/slug for profile URL
  password      String?
  image         String?
  role          String    @default("USER") // USER, CREATOR, ADMIN
  bio           String?   // Creator bio/description
  bannerUrl     String?   // Profile banner image
  socialLinks   Json?     // Stores social media links (twitter, youtube, website, etc.)
  
  // Security & Tracking
  lastLoginIp   String?
  lastLoginAt   DateTime?

  resetToken    String?
  resetTokenExpiry DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  favorites     Product[] @relation("UserFavorites")
  purchases     Order[]
  createdProducts Product[] @relation("UserProducts")
}

model Product {
  id          String   @id @default(uuid())
  slug        String   @unique @default(cuid()) // Default to cuid to handle existing records
  title       String
  description String
  price       Float
  previewUrl  String   // Path to the model3.json file relative to public folder or S3 URL
  fileUrl     String   // Path to the downloadable zip file (secure location)
  iconUrl     String?  // Path to the icon image
  isSold      Boolean  @default(false)
  sex         String?  // Male, Female, Other
  eyeColor    String?
  hairColor   String?
  bodyType    String?
  theme       String?
  tags        String[] // General tags
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNote   String?  // Reason for rejection or other admin notes
  mediaUrls   String[] // Array of URLs for additional screenshots, gifs, videos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Order       Order[]
  favoritedBy User[]   @relation("UserFavorites")
  creatorId   String?
  creator     User?    @relation("UserProducts", fields: [creatorId], references: [id])
}

model Order {
  id            String   @id @default(uuid())
  paymentId     String   // PayPal Order ID
  amount        Float
  status        String   // PENDING, COMPLETED, FAILED
  buyerEmail    String?  // For guest checkout tracking
  
  // Tracking
  purchaseIp    String?
  userAgent     String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  items         OrderItem[]
  downloadLogs  DownloadLog[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  price     Float
}

model DownloadLog {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  userId    String?  // Optional, if user was logged in
  user      User?    @relation(fields: [userId], references: [id])
  productId String?  // Which file was downloaded
  product   Product? @relation(fields: [productId], references: [id])
  
  ip        String
  userAgent String?
  status    String   // SUCCESS, FAILED
  reason    String?  // Error message if failed
  
  downloadedAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
}
